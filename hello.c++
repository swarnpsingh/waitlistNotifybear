#include <iostream>
using namespace std;
int main () {
double radius = 2;  //in feet
double depth = 0.33;
double gallons;

//formula 
gallons = 3.14 * radius * radius * depth * 7.5;
// output statemnet
cout << "The volume of water in a Kiddle pool with radius "
<< radius  << " feet and depth "
<<  depth  << " feet is "
<<  gallons  << " gallons. " << endl;






}